    "Q5. Loop and Function Reasoning\n",
    "\n",
    "Ans:-\n",
    "\n",
    "def readiness_score(attendance, diary, tasks):\n",
    "    score = attendance * 0.5 + diary * 2 + tasks * 3\n",
    "\n",
    "    if score >= 90:\n",
    "        return 100\n",
    "    elif score >= 70:\n",
    "        return 80\n",
    "    else:\n",
    "        return 60"
